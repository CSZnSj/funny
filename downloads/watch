بدالناصر\n‎21:37 مرحله‌ی دوم ظهور ناجی\n‎22:40 رضاشاه فرمانده‌ی قزاق‌ها\n‎23:51 مصطفی کمال آتاتورک\n‎24:35 ناجی‌های در سایه نشسته\n‎25:46 دعوت جامعه از ناجی بناپارتیست\n‎26:11 مرحله‌ی سوم اصلاحات و اقتدارگرایی در فرانسه و ایران رضاشاه\n‎28:18 اقتدارگرایی آتاتورک و ساختن کشور ترکیه\n‎29:04 اقتدارگرایی ناصر در مصر\n‎29:33 نظم و توسعه در ازای آزادی\n‎31:41 اشتباه بزرگ و پایان خراب\n‎34:01 اشغال ایران و پایان رضاشاه\n‎35:41 پایان جمال عبدالناصر\n‎36:20 آتاتورک نمونه‌ی موفق مدرنیزاسیون اقتدارگرای بناپارتی\n‎38:15 دلیل سقوط: تمرکز قدرت و جامعه‌ی ضعیف\n‎41:33 آینده‌ی ایران و بناپارتیسم\n‎43:19 بحران فعلی ایران\n‎44:16 چرا ایران زمینه‌ی بناپارتیسم دارد\n‎45:39 ترس جامعه از فروپاشی ایران\n‎46:38 خشم مردم از سرکوب گسترده و ناجی ایران\n‎49:37 تمرکز روی پایداری ملی به جای ایدئولوژی\n‎51:12 همکاری تکنوکرات‌ها و نخبگان با ناجی\n‎51:40 چه زمانی احتمال این سناریو هست؟\n‎52:38 آزادی در ایران به کجا می‌رسه؟\n‎54:33 تصمیم‌های ما نقشی در روند تاریخ دارند؟\n‎55:33 تاریخ چند بار تکرار می‌شود؟\n\nدر این ویدیو از تعریف الگوی بناپارتیسم کارل مارکس شروع می‌کنیم، زمینه‌های ایجاد و مراحل بناپارتیسم رو با مثال‌های ترکیه و آتاتورک، فرانسه و ناپلئون، ایران و رضاشاه، مصر و جمال عبدالناصر می‌گیم و در آخر به آینده‌ی ایران می‌رسیم: بحران فعلی ایران چه بستری برای ظهور بناپارت جدید ساخته و یا می‌سازه؟ خشم مردم از سرکوب گسترده به کجا می‌رسه و تمرکز روی پایداری ملی به جای ایدئولوژی چطور ممکنه؟\n\n✅ پشتیبانی از بی‌پلاس https://bpluspodcast.com/support\n☑️ وبسایت بی‌پلاس https://bpluspodcast.com/\n✅ پادکست بی‌پلاس https://bpluspodcast.com/how-to-listen\n☑️ کانال تلگرام بی‌پلاس https://t.me/podcastbplus","commandRuns":[{"startIndex":160,"length":4,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAciEwjAg6GwgrmUAxXCR_IAHThDBP3KAQSfUxY4","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=oaKqW_t6acs","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"oaKqW_t6acs","continuePlayback":true,"startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnes